<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Responsive Chat Application UI</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @import url("https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap");
      body {
        font-family: "Inter", sans-serif;
        background-color: #f3f4f6;
      }
      .custom-scrollbar::-webkit-scrollbar {
        width: 8px;
      }
      .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: #cbd5e1;
        border-radius: 4px;
      }
      .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f5f9;
      }
    </style>
  </head>
  <body class="min-h-screen flex items-center justify-center p-4 sm:p-6">
    <div
      id="chat-container"
      class="w-full max-w-6xl h-[90vh] bg-white rounded-2xl shadow-2xl flex overflow-hidden"
    >
      <!-- Sidebar: User List -->
      <aside
        id="sidebar"
        class="flex w-full md:w-1/4 lg:w-1/5 border-r border-gray-200 bg-gray-50 flex-col transition-all duration-300 md:flex"
      >
        <header class="p-4 border-b border-gray-200">
          <h2 class="text-xl font-bold text-gray-800">Users</h2>
        </header>
        <div id="user-list" class="flex-1 overflow-y-auto custom-scrollbar">
          <% if (!allusers.length) { %>
          <h3 class="p-3 text-gray-500">No Users</h3>
          <% } %> <% allusers.forEach(user => { %>
          <div
            class="p-3 border-b border-gray-100 hover:bg-blue-50 cursor-pointer transition flex items-center justify-between user-item"
            data-id="<%= user._id %>"
            data-username="<%= user.name %>"
          >
            <span class="font-semibold text-gray-700"><%= user.name %></span>
            <span class="w-3 h-3 bg-green-500 rounded-full"></span>
          </div>
          <% }) %>
        </div>
        <footer
          class="p-2 border-t border-gray-200 text-center text-sm text-gray-500"
        >
          <a href="#" class="text-blue-500 hover:text-blue-600">Settings</a>
        </footer>
      </aside>

      <!-- Main Chat Area -->
      <section id="chat-main" class="flex-1 flex flex-col hidden md:flex">
        <!-- Chat Header -->
        <header
          class="p-4 border-b border-gray-200 bg-white shadow-sm flex items-center justify-between"
        >
          <div class="flex items-center space-x-3">
            <button
              id="back-button"
              class="md:hidden p-2 text-gray-600 hover:text-gray-800 rounded-full hover:bg-gray-100 transition"
              onclick="closeChat()"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M10 19l-7-7m0 0l7-7m-7 7h18"
                />
              </svg>
            </button>
            <h2
              id="current-chat-user"
              class="text-xl font-semibold text-gray-800"
            >
              Select a user to chat
            </h2>
          </div>
        </header>

        <!-- Messages Container -->
        <div
          id="messages-container"
          class="flex-1 overflow-y-auto p-4 space-y-4 custom-scrollbar bg-gray-50"
        >
          <!-- Messages will appear here -->
        </div>

        <!-- Input Footer -->
        <footer class="p-4 border-t border-gray-200 bg-white">
          <div id="input-form" class="flex space-x-3">
            <input
              type="text"
              placeholder="Type your message here..."
              class="flex-1 p-3 border border-gray-300 rounded-xl focus:ring-blue-500 focus:border-blue-500 transition"
              id="message-input"
            />
            <button
              type="submit"
              class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-xl transition duration-200 shadow-lg hover:shadow-xl"
              onclick="sendMessage()"
            >
              Send
            </button>
          </div>
        </footer>
      </section>
    </div>
    <script src="/socket.io/socket.io.js"></script>
    <script>
      const userId = "<%=userid%>";
    </script>

    <script>
        if ("Notification" in window && Notification.permission !== "granted") {
    Notification.requestPermission().then((permission) => {
      console.log("Notification permission:", permission);
    });
  }
      let friendId = null;
      const socket = io();
      socket.emit("registerUser", userId);
      const sidebar = document.getElementById("sidebar");
      const chatMain = document.getElementById("chat-main");
      const chatUserHeader = document.getElementById("current-chat-user");
      const messagesContainer = document.getElementById("messages-container");
      const userItems = document.querySelectorAll(".user-item");
   
      socket.on("message", (msg) => {

    if (!friendId) return;
    if (msg.senderId === userId) return;

    // Only append messages from the friend
    if (msg.senderId === friendId) {
        appendMessage(msg);
    }
});



  // ✅ Listen for notifications sent from server
  socket.on("receiveNotification", (data) => {
    console.log("New Notification:", data);

    if (Notification.permission === "granted") {
      new Notification("📩 New Notification", {
        body: data.message,
         // optional icon path
      });
    }
  });
      // Function to open chat
      function openChat(username) {
        if (!friendId) return;

        fetch(`/chats/${friendId}`) // assuming backend route takes both IDs
          .then((res) => res.json())
          .then((response) => {
            // Clear previous messages
            messagesContainer.innerHTML = "";
            const messages = response.data || [];

            // Display messages differently for sender vs receiver
            if (!messages.length) {
              messagesContainer.innerHTML = "No messages";
            }
            messages.forEach((msg) => {
              const div = document.createElement("div");

              if (msg.sender === userId) {
                // Message sent by logged-in user
                div.className = "flex justify-end";
                div.innerHTML = `
                        <div class="max-w-xs lg:max-w-md p-3 bg-blue-600 text-white rounded-xl rounded-tr-none shadow-md">
                            <p>${msg.message}</p>
                            <span class="text-xs opacity-70 mt-1 block text-right">${new Date(
                              msg.timestamp
                            ).toLocaleTimeString()}</span>
                        </div>
                    `;
              } else {
                // Message received from friend
                div.className = "flex justify-start";
                div.innerHTML = `
                        <div class="max-w-xs lg:max-w-md p-3 bg-gray-200 text-gray-800 rounded-xl rounded-tl-none shadow-md">
                            <p>${msg.message}</p>
                            <span class="text-xs text-gray-500 mt-1 block text-left">${new Date(
                              msg.timestamp
                            ).toLocaleTimeString()}</span>
                        </div>
                    `;
              }

              messagesContainer.appendChild(div);
            });

            // Scroll to bottom
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            // Update chat header
            chatUserHeader.textContent = "Chatting with: " + username;

            // Show chat area on small screens
            if (window.innerWidth < 768) {
              sidebar.classList.add("hidden");
              sidebar.classList.remove("flex");
              chatMain.classList.remove("hidden");
              chatMain.classList.add("flex");
            }
          })
          .catch((err) => console.error("Failed to load messages:", err));
      }

      

      // Function to append a message to the messages container
      function appendMessage(msg) {
        const div = document.createElement("div");

        if (msg.sender === userId) {
          // Message sent by logged-in user
          div.className = "flex justify-end";
          div.innerHTML = `
                        <div class="max-w-xs lg:max-w-md p-3 bg-blue-600 text-white rounded-xl rounded-tr-none shadow-md">
                            <p>${msg.message}</p>
                            <span class="text-xs opacity-70 mt-1 block text-right">${new Date().toLocaleTimeString()}</span>
                        </div>
                    `;
        } else {
          // Message received from friend
          div.className = "flex justify-start";
          div.innerHTML = `
                        <div class="max-w-xs lg:max-w-md p-3 bg-gray-200 text-gray-800 rounded-xl rounded-tl-none shadow-md">
                            <p>${msg.message}</p>
                            <span class="text-xs text-gray-500 mt-1 block text-left">${new Date().toLocaleTimeString()}</span>
                        </div>
                    `;
        }

        messagesContainer.appendChild(div);
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }

      // Function to close chat on mobile
      function closeChat() {
        if (window.innerWidth < 768) {
          chatMain.classList.add("hidden");
          chatMain.classList.remove("flex");
          sidebar.classList.remove("hidden");
          sidebar.classList.add("flex");
        }
      }

      // Add click event to all users
      userItems.forEach((item) => {
        item.addEventListener("click", function () {
          // Remove active styles from all
          userItems.forEach((i) => {
            i.classList.remove("bg-blue-100", "active-chat");
            const span = i.querySelector("span:first-child");
            if (span) {
              span.classList.remove("text-blue-700", "font-semibold");
              span.classList.add("text-gray-700");
            }
          });

          // Add active style to clicked user
          this.classList.add("bg-blue-100", "active-chat");
          const span = this.querySelector("span:first-child");
          if (span) {
            span.classList.add("font-semibold", "text-blue-700");
            span.classList.remove("text-gray-700");
          }

          // Get username and ID
          const username = this.dataset.username;
          const userId = this.dataset.id;
          friendId = this.dataset.id;
          // Open chat
          openChat(username);

          console.log("Selected User:", username, "ID:", userId);
        });
      });

      // Send message (for now just adds to container)
      function sendMessage() {
        const input = document.getElementById("message-input");
        const content = input.value.trim();
        if (!content) return;

        if (!friendId) {
          alert("Select a user to chat with!");
          return;
        }

        // Emit message to server via Socket.IO
        socket.emit("message", {
          senderId: userId, 
          receiverId: friendId, 
                    message: content,
        });

        // Display the message locally
        const div = document.createElement("div");
        div.className = "flex justify-end";
        div.innerHTML = `
        <div class="max-w-xs lg:max-w-md p-3 bg-blue-600 text-white rounded-xl rounded-tr-none shadow-md">
            <p>${content}</p>
            <span class="text-xs opacity-70 mt-1 block text-right">${new Date().toLocaleTimeString()}</span>
        </div>
    `;
        messagesContainer.appendChild(div);
        input.value = "";
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }
    </script>
  </body>
</html>
