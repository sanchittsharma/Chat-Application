<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Connectly - Real-time Messaging for Teams</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #080B14;
      --primary: #4F46E5;
      --accent: #7C3AED;
      --cyan: #22D3EE;
    }
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background-color: var(--bg);
      color: white;
      overflow-x: hidden;
    }
    .glass {
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.08);
    }
    .glow {
      position: absolute;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(79, 70, 229, 0.15) 0%, rgba(124, 58, 237, 0.05) 50%, transparent 100%);
      filter: blur(60px);
      z-index: -1;
    }
    .input-field {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: white;
      transition: all 0.3s ease;
    }
    .input-field:focus {
      background: rgba(255, 255, 255, 0.06);
      border-color: var(--cyan);
      box-shadow: 0 0 20px rgba(34, 211, 238, 0.1);
    }
    .btn-gradient {
      background: linear-gradient(135deg, var(--primary), var(--accent));
      transition: all 0.3s ease;
    }
    .btn-gradient:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(79, 70, 229, 0.3);
    }
    .fade-in {
      animation: fadeIn 0.8s ease-out forwards;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body class="relative min-h-screen">
  <!-- Glow Backgrounds -->
  <div class="glow top-0 left-0"></div>
  <div class="glow bottom-0 right-0" style="background: radial-gradient(circle, rgba(34, 211, 238, 0.1) 0%, transparent 70%);"></div>

  <!-- Navbar -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-6 fade-in">
    <div class="max-w-7xl mx-auto flex justify-between items-center glass rounded-2xl px-8 py-4">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 btn-gradient rounded-lg flex items-center justify-center font-bold text-white italic">C</div>
        <span class="text-xl font-bold tracking-tight">Connectly</span>
      </div>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-400">
        <a href="/about" class="hover:text-white transition-colors">Features</a>
        <!-- <a href="/about" class="hover:text-white transition-colors">Pricing</a> -->
        <a href="/about" class="hover:text-white transition-colors">About</a>
        <!-- <a href="https://github.com" class="hover:text-white transition-colors">GitHub</a> -->
      </div>
      <div class="flex items-center gap-4">
        <button onclick="toggleForms()" class="text-sm font-semibold hover:text-cyan-400 transition-colors">Log in</button>
        <button onclick="toggleForms()" class="px-5 py-2 rounded-xl btn-gradient text-sm font-bold shadow-lg">Sign up</button>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <main class="pt-32 pb-20 px-6 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
      <div class="space-y-10 fade-in" style="animation-delay: 0.2s;">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-400 text-xs font-bold tracking-widest uppercase">
          <span class="w-2 h-2 bg-indigo-500 rounded-full animate-pulse"></span>
          Now in Beta v2.0
        </div>
        <h1 class="text-7xl lg:text-8xl font-extrabold tracking-tighter leading-[0.85] text-white">
          Connect<br/>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 via-purple-400 to-cyan-400">instantly</span><br/>
          with your team.
        </h1>
        <p class="text-xl text-slate-400 max-w-md leading-relaxed">
          The fastest and most beautiful way to manage team conversations. Real-time, secure, and built for modern workflows.
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <button onclick="toggleForms()" class="px-8 py-4 rounded-2xl btn-gradient text-white font-bold text-lg shadow-2xl shadow-indigo-500/20 active:scale-95">
            Start Chatting
          </button>
          <!-- <a href="https://github.com" class="px-8 py-4 rounded-2xl glass text-white font-bold text-lg hover:bg-white/5 transition-all flex items-center gap-2">
            View GitHub
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          </a> -->
        </div>
        
        <div class="pt-12 flex items-center gap-6">
          <div class="flex -space-x-3">
            <div class="w-12 h-12 rounded-full border-2 border-bg bg-indigo-600 flex items-center justify-center font-bold">JD</div>
            <div class="w-12 h-12 rounded-full border-2 border-bg bg-purple-600 flex items-center justify-center font-bold">AS</div>
            <div class="w-12 h-12 rounded-full border-2 border-bg bg-cyan-600 flex items-center justify-center font-bold">MK</div>
          </div>
          <p class="text-sm text-slate-500 font-medium tracking-wide">
            Trusted by <span class="text-white font-bold">2,000+</span> teams worldwide.
          </p>
        </div>
      </div>

      <!-- Hero Illustration / Auth Forms -->
      <div class="relative flex flex-col items-center">
        <!-- Floating UI Mockup (Reference Image) -->
        <div id="hero-image" class="w-full relative group fade-in" style="animation-delay: 0.4s;">
          <div class="absolute -inset-4 bg-gradient-to-r from-indigo-500 to-cyan-500 rounded-[3rem] blur-2xl opacity-10 group-hover:opacity-20 transition duration-1000"></div>
          <img src="/images/connectly_hero.png" alt="Connectly Dashboard" class="relative rounded-[2rem] shadow-2xl border border-white/5 transform hover:scale-[1.01] transition-transform duration-700">
          
          <!-- Floating Status Indicator -->
          <div class="absolute top-10 -left-10 glass p-4 rounded-2xl shadow-2xl flex items-center gap-4 animate-bounce" style="animation-duration: 3s;">
            <div class="relative">
              <div class="w-10 h-10 rounded-full bg-cyan-500/20 border border-cyan-500/30"></div>
              <div class="absolute bottom-0 right-0 w-3 h-3 bg-cyan-400 rounded-full border-2 border-bg"></div>
            </div>
            <div>
              <p class="text-xs font-bold">Alex Rivera</p>
              <p class="text-[10px] text-cyan-400">Typing...</p>
            </div>
          </div>
        </div>

        <!-- Forms (Hidden by default, triggered by CTA) -->
        <div id="auth-container" class="hidden w-full max-w-md space-y-8 fade-in">
          <!-- Login -->
          <div id="login-container" class="glass rounded-[2rem] p-10 shadow-2xl">
            <h2 class="text-4xl font-bold mb-2">Welcome Back</h2>
            <p class="text-slate-400 mb-8">Enter your credentials to continue.</p>
            <form id="loginForm" class="space-y-6">
              <div>
                <label class="block text-sm font-bold text-slate-300 mb-2 ml-1">Username</label>
                <input type="text" name="name" required class="input-field w-full px-6 py-4 rounded-2xl outline-none" placeholder="alex_rivera">
              </div>
              <div>
                <label class="block text-sm font-bold text-slate-300 mb-2 ml-1">Password</label>
                <input type="password" name="password" required class="input-field w-full px-6 py-4 rounded-2xl outline-none" placeholder="••••••••">
              </div>
              <div class="flex justify-end">
                <button type="button" onclick="showResetModal()" class="text-xs text-indigo-400 font-bold hover:text-white transition-colors">Forgot Password?</button>
              </div>
              <button type="submit" class="w-full py-4 rounded-2xl btn-gradient text-white font-bold text-lg shadow-xl active:scale-95">
                Sign In
              </button>
            </form>
            <div class="mt-8 text-center pt-6 border-t border-white/5">
              <button onclick="toggleAuth('register')" class="text-sm text-slate-400">New here? <span class="text-white font-bold underline decoration-indigo-500 underline-offset-4">Create Account</span></button>
            </div>
          </div>

          <!-- Register -->
          <div id="register-container" class="hidden glass rounded-[2rem] p-10 shadow-2xl">
            <h2 class="text-4xl font-bold mb-2">Join Connectly</h2>
            <p class="text-slate-400 mb-8">Start chatting with your team today.</p>
            <form id="registerForm" class="space-y-5">
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-bold text-slate-300 mb-2 ml-1">Name</label>
                  <input type="text" name="name" required class="input-field w-full px-6 py-4 rounded-2xl outline-none" placeholder="Alex">
                </div>
                <div>
                  <label class="block text-sm font-bold text-slate-300 mb-2 ml-1">Email</label>
                  <input type="email" name="email" required class="input-field w-full px-6 py-4 rounded-2xl outline-none" placeholder="alex@work.com">
                </div>
              </div>
              <div>
                <label class="block text-sm font-bold text-slate-300 mb-2 ml-1">Password</label>
                <input type="password" name="password" required class="input-field w-full px-6 py-4 rounded-2xl outline-none" placeholder="Create password">
              </div>
              <div>
                <label class="block text-sm font-bold text-slate-300 mb-2 ml-1">Confirm</label>
                <input type="password" name="confirmpassword" required class="input-field w-full px-6 py-4 rounded-2xl outline-none" placeholder="Confirm password">
              </div>
              <button type="submit" class="w-full py-4 rounded-2xl btn-gradient text-white font-bold text-lg shadow-xl active:scale-95">
                Create Account
              </button>
            </form>
            <div class="mt-8 text-center pt-6 border-t border-white/5">
              <button onclick="toggleAuth('login')" class="text-sm text-slate-400">Already a member? <span class="text-white font-bold underline decoration-indigo-500 underline-offset-4">Sign In</span></button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Features Grid -->
    <div class="mt-40 grid grid-cols-1 md:grid-cols-3 gap-8 fade-in" style="animation-delay: 0.6s;">
      <div class="glass p-10 rounded-[2.5rem] hover:bg-white/5 transition-all group">
        <div class="w-14 h-14 rounded-2xl bg-indigo-500/10 flex items-center justify-center text-indigo-400 mb-8 group-hover:scale-110 transition-transform">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="text-2xl font-bold mb-4">Ultra Real-time</h3>
        <p class="text-slate-400 leading-relaxed">Experience zero-latency messaging with our distributed socket architecture.</p>
      </div>
      <div class="glass p-10 rounded-[2.5rem] hover:bg-white/5 transition-all group">
        <div class="w-14 h-14 rounded-2xl bg-purple-500/10 flex items-center justify-center text-purple-400 mb-8 group-hover:scale-110 transition-transform">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
        </div>
        <h3 class="text-2xl font-bold mb-4">Smart Groups</h3>
        <p class="text-slate-400 leading-relaxed">Create dynamic rooms for teams, projects, or just random watercooler talk.</p>
      </div>
      <div class="glass p-10 rounded-[2.5rem] hover:bg-white/5 transition-all group">
        <div class="w-14 h-14 rounded-2xl bg-cyan-500/10 flex items-center justify-center text-cyan-400 mb-8 group-hover:scale-110 transition-transform">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
        </div>
        <h3 class="text-2xl font-bold mb-4">Enterprise Security</h3>
        <p class="text-slate-400 leading-relaxed">JWT authentication and bcrypt hashing to keep your data completely private.</p>
      </div>
    </div>
  </main>

  <!-- Password Reset Modal -->
  <div id="reset-modal" class="fixed inset-0 bg-bg/90 z-[100] hidden items-center justify-center p-4 backdrop-blur-xl">
    <div class="glass rounded-[2.5rem] p-10 w-full max-w-md shadow-2xl fade-in">
      <div class="flex justify-between items-center mb-8">
        <h2 class="text-3xl font-bold">Reset Password</h2>
        <button onclick="hideResetModal()" class="text-slate-400 hover:text-white text-3xl transition-colors">&times;</button>
      </div>
      <div class="bg-indigo-500/10 border border-indigo-500/20 rounded-2xl p-5 mb-8 flex items-start gap-4">
        <div class="w-2 h-2 bg-indigo-500 rounded-full mt-2 animate-pulse"></div>
        <div>
          <p class="text-xs font-bold text-indigo-400 uppercase tracking-widest">Maintenance Notice</p>
          <p class="text-xs text-indigo-100/60 mt-1 leading-relaxed">Our email dispatch servers are currently offline for maintenance. Recovery is temporarily disabled.</p>
        </div>
      </div>
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-bold text-slate-500 mb-2 ml-1">Email Address</label>
          <input type="email" disabled class="input-field w-full px-6 py-4 rounded-2xl outline-none opacity-40 cursor-not-allowed" placeholder="alex@work.com">
        </div>
        <button disabled class="w-full py-4 rounded-2xl bg-slate-800 text-slate-500 font-bold cursor-not-allowed">
          System Offline
        </button>
      </div>
    </div>
  </div>

  <script>
    function toggleForms() {
      const heroImage = document.getElementById('hero-image');
      const authContainer = document.getElementById('auth-container');
      
      if (authContainer.classList.contains('hidden')) {
        heroImage.classList.add('hidden');
        authContainer.classList.remove('hidden');
      } else {
        heroImage.classList.remove('hidden');
        authContainer.classList.add('hidden');
      }
    }

    function toggleAuth(type) {
      const login = document.getElementById('login-container');
      const register = document.getElementById('register-container');
      if (type === 'register') {
        login.classList.add('hidden');
        register.classList.remove('hidden');
      } else {
        login.classList.remove('hidden');
        register.classList.add('hidden');
      }
    }

    function showResetModal() {
      document.getElementById('reset-modal').classList.remove('hidden');
      document.getElementById('reset-modal').classList.add('flex');
    }

    function hideResetModal() {
      document.getElementById('reset-modal').classList.remove('flex');
      document.getElementById('reset-modal').classList.add('hidden');
    }

    // Auth Handlers
    document.getElementById("loginForm").addEventListener("submit", async function (event) {
      event.preventDefault();
      const formData = new URLSearchParams(new FormData(this));
      try {
        const res = await fetch("/auth/login", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: formData,
        });
        const data = await res.json();
        if (data.success) {
          window.location.href = "/chats";
        } else {
          alert(data.message || "Login failed");
        }
      } catch (err) {
        console.error("Error:", err);
      }
    });

    document.getElementById("registerForm").addEventListener("submit", async function (event) {
      event.preventDefault();
      const formData = new URLSearchParams(new FormData(this));
      try {
        const res = await fetch("/auth/register", {
          method: "POST",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body: formData,
        });
        const data = await res.json();
        if (data.success) {
          alert("Registration successful! Please login.");
          toggleAuth('login');
        } else {
          alert(data.message || "Registration failed");
        }
      } catch (err) {
        console.error("Error:", err);
      }
    });
  </script>
</body>
</html>
